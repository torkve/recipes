# Copy to .env and edit. docker compose reads this file automatically.

# First admin account, created on first start (required).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Host port to publish (container always listens on 8080).
RECIPES_PORT=8080

# Site name shown in the header.
RECIPES_SITE_NAME=Семейная кулинарная книга

# Set true when the site is served over HTTPS (e.g. behind a TLS proxy),
# so session and CSRF cookies are marked Secure.
RECIPES_SECURE_COOKIES=false

# iCloud Notes two-way sync. Off by default; when enabled, bind an Apple ID
# (with two-factor) from Admin -> iCloud. Requires outbound HTTPS to Apple.
RECIPES_ICLOUD_ENABLED=false
RECIPES_ICLOUD_PULL_MINUTES=15
# SRP byte convention for Apple sign-in (0..5). Apple throttles repeated
# attempts, so binding tries only this one; if sign-in fails with 401, set the
# next value and re-bind. Default 1.
RECIPES_ICLOUD_SRP_VARIANT=1
